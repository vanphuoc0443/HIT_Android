<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/themeBottomBg"
    tools:context=".MainActivity"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:id="@+id/displayPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/themeDisplayBg"
        android:orientation="vertical"
        android:padding="18dp"
        app:layout_constraintBottom_toTopOf="@+id/keypadPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.40"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivSettings"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_menu"
            app:tint="?attr/themeIconSettings" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text=""
            android:alpha="0.7"
            android:textColor="?attr/themeTextDisplay"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0"
            android:textColor="?attr/themeTextDisplay"
            android:textSize="64sp"
            android:textStyle="normal" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/keypadPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/themeKeypadBg"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAC"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnOperatorBg"
                android:text="AC"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnOperator"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnOperatorBg"
                android:text="&lt;"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnOperator"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPercent"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnOperatorBg"
                android:text="%"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnOperator"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDivide"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnMathOpBg"
                android:text="/"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnMathOp"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn7"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="7"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn8"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="8"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn9"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="9"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnMultiply"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnMathOpBg"
                android:text="*"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnMathOp"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn4"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="4"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn5"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="5"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn6"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="6"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnMinus"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnMathOpBg"
                android:text="-"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnMathOp"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="1"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn2"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="2"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn3"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="3"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPlus"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnMathOpBg"
                android:text="+"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnMathOp"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="0"
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDot"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnNumberBg"
                android:text="."
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnNumber"
                android:textSize="24sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEqual"
                android:layout_width="0dp"
                android:layout_height="82dp"
                android:layout_margin="6dp"
                android:layout_weight="2"
                android:background="@drawable/shape_calculator_btn"
                app:backgroundTint="?attr/themeBtnEqualBg"
                android:text="="
                android:textAllCaps="false"
                android:textColor="?attr/themeTextBtnEqual"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
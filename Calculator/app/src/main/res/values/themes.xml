        <item name="themeDisplayBg">@color/light_display_bg</item>
        <item name="themeKeypadBg">@color/light_keypad_bg</item>
        <item name="themeBottomBg">@color/light_keypad_bg</item>
        <item name="themeBtnNumberBg">@color/light_btn_num_bg</item>
        <item name="themeBtnOperatorBg">@color/light_btn_op_bg</item>
        <item name="themeBtnMathOpBg">@color/light_btn_op_bg</item>
        <item name="themeBtnEqualBg">@color/light_btn_eq_bg</item>
        <item name="themeTextDisplay">@color/light_text_display</item>
        <item name="themeIconSettings">@color/light_text_display</item>
        <item name="themeTextBtnNumber">@color/light_text_btn_num</item>
        <item name="themeTextBtnOperator">@color/light_text_btn_num</item>
        <item name="themeTextBtnMathOp">@color/light_text_btn_num</item>
        <item name="themeTextBtnEqual">@color/light_text_btn_eq</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

